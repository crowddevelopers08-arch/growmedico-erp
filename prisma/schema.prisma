generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  role          String    @default("EMPLOYEE")
  employeeId    String?   @unique
  employee      Employee? @relation(fields: [employeeId], references: [id])
  notifications Json?
  preferences   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Employee {
  id               String          @id @default(cuid())
  name             String
  email            String          @unique
  phone            String
  avatar           String?
  initials         String
  department       String
  role             String
  status           String          @default("present")
  joinDate         String
  salary           Float
  address          String
  emergencyContact String
  dateOfBirth      String
  user             User?
  attendance       Attendance[]
  leaveRequests    LeaveRequest[]
  salaryRecords    SalaryRecord[]
  activities       Activity[]
  tasks            Task[]
  projectMembers   ProjectMember[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Attendance {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date          String
  checkIn       String?
  checkOut      String?
  checkInPhoto  String?
  checkOutPhoto String?
  status        String
  workHours     Float    @default(0)
  overtime      Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeId, date])
}

model LeaveRequest {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type            String
  startDate       String
  endDate         String
  days            Int
  reason          String
  status          String   @default("pending")
  appliedOn       String
  approvedBy      String?
  approvedOn      String?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SalaryRecord {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month      String
  year       Int
  baseSalary Float
  bonus      Float    @default(0)
  deductions Float    @default(0)
  overtime   Float    @default(0)
  netSalary  Float
  status     String   @default("pending")
  paidOn     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, month, year])
}

model Activity {
  id          String    @id @default(cuid())
  type        String
  action      String
  description String
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  createdAt   DateTime  @default(now())
}

model Task {
  id           String         @id @default(cuid())
  title        String
  description  String?
  projectId    String?
  project      ClientProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignedToId String
  assignedTo   Employee       @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedById String
  assignedByName   String?
  assignedByAvatar String?
  priority     String         @default("medium")
  status       String         @default("pending")
  stage        String         @default("Unstaged Tasks")
  dueDate      String?
  comments     TaskComment[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ClientProject {
  id          String          @id @default(cuid())
  clientName  String
  name        String
  description String?
  status      String          @default("open")
  priority    String          @default("medium")
  dueDate     String?
  createdById String
  tasks       Task[]
  members     ProjectMember[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([clientName, name])
}

model ProjectMember {
  id         String        @id @default(cuid())
  projectId  String
  project    ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@unique([projectId, employeeId])
}

model TaskComment {
  id           String    @id @default(cuid())
  taskId       String
  task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  senderId     String
  senderName   String
  senderAvatar String?
  content      String    @default("")
  audioContent String?
  attachments  Json?
  mentions     String[]
  editedAt     DateTime?
  createdAt    DateTime  @default(now())
}

model Channel {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdById String
  messages    Message[]
  createdAt   DateTime  @default(now())
}

model Message {
  id           String    @id @default(cuid())
  channelId    String
  channel      Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId     String
  senderName   String
  senderAvatar String?
  content      String    @default("")
  audioContent String?
  attachments  Json?
  mentions     String[]
  readBy       String[]  @default([])
  editedAt     DateTime?
  createdAt    DateTime  @default(now())
}

model CompanySettings {
  id         String   @id @default("global")
  name       String   @default("")
  email      String   @default("")
  phone      String   @default("")
  address    String   @default("")
  website    String   @default("")
  timezone   String   @default("Asia/Kolkata")
  dateFormat String   @default("DD/MM/YYYY")
  currency   String   @default("INR")
  updatedAt  DateTime @updatedAt
}
